{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor",
    "schedule:daily",
    ":automergeBranch",
    ":automergeDigest",
    ":automergePatch",
    ":disableDependencyDashboard"
  ],
  "labels": ["dependencies"],
  "reviewers": ["Nitestack"],
  "timezone": "Europe/Berlin",
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track digest-pinned OCI images referenced in Nix homelab modules",
      "managerFilePatterns": ["**/*.nix"],
      "matchStrings": [
        "image\\s*=\\s*(?:lib\\.mkDefault\\s*)?\"(?<depName>[\\w.\\-/]+):(?<currentValue>[\\w.\\-]+)@sha256:(?<currentDigest>[a-f0-9]{64})\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "addLabels": ["docker"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io/immich-app/immich-(server|machine-learning)$/"],
      "groupName": "Immich"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io/seanmorley15/adventurelog-(frontend|backend)$/"],
      "groupName": "Adventure Log"
    }
  ]
}
